# ── GetFit AI Service Environment ──

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Multi-Model Specialization (latency optimization)
OLLAMA_FAST_MODEL=qwen3:1.7b
OLLAMA_EVALUATOR_MODEL=qwen3:8b
OLLAMA_COMPRESSOR_MODEL=qwen3:1.7b
OLLAMA_KEEP_ALIVE=300

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
API_PORT=8100
DEBUG=true

# S3 / Video Storage (for video analysis feature)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=getfit-videos
