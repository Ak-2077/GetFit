# ── GetFit AI Service Environment ──

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Multi-Model Specialization (latency optimization)
OLLAMA_FAST_MODEL=qwen3:1.7b
OLLAMA_EVALUATOR_MODEL=qwen3:8b
OLLAMA_COMPRESSOR_MODEL=qwen3:1.7b
OLLAMA_KEEP_ALIVE=300

# ── Vision Adapter (modular food vision) ──
# Primary vision model for food analysis: qwen2.5-vl | moondream | gemini | florence2
VISION_PRIMARY=qwen2.5-vl
# Automatic fallback when primary is unavailable/fails/times out
VISION_FALLBACK=moondream
# Ollama tag for Qwen2.5-VL (pull with: ollama pull qwen2.5vl:7b)
OLLAMA_QWEN_VL_MODEL=qwen2.5vl:7b
OLLAMA_VISION_FAST_MODEL=moondream
VISION_TIMEOUT=60
VISION_FALLBACK_TIMEOUT=30
# GEMINI_API_KEY=   # future

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
API_PORT=8100
DEBUG=true

# S3 / Video Storage (for video analysis feature)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=getfit-videos
