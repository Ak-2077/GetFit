# ── GetFit AI Service Environment ──

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Multi-Model Specialization (latency optimization)
OLLAMA_FAST_MODEL=qwen3:1.7b
OLLAMA_EVALUATOR_MODEL=qwen3:8b
OLLAMA_COMPRESSOR_MODEL=qwen3:1.7b
OLLAMA_KEEP_ALIVE=300

# ── Vision Adapter (modular food vision) ──
# Primary vision model for food analysis: qwen2.5-vl | moondream | gemini | florence2
VISION_PRIMARY=qwen2.5-vl
# Automatic fallback when primary is unavailable/fails/times out
VISION_FALLBACK=moondream
# Ollama tag for Qwen2.5-VL (pull with: ollama pull qwen2.5vl:7b)
OLLAMA_QWEN_VL_MODEL=qwen2.5vl:7b
OLLAMA_VISION_FAST_MODEL=moondream
VISION_TIMEOUT=60
VISION_FALLBACK_TIMEOUT=30
# GEMINI_API_KEY=   # future

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
API_PORT=8100
DEBUG=true

# S3 / Video Storage (for video analysis feature)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=getfit-videos

# ── AI Exercise Analysis Pipeline ──
# Engine / strategy selection (config-driven, swappable backends)
# POSE_ENGINE: mediapipe|movenet|blazepose|openpose
POSE_ENGINE=mediapipe
# SMOOTHING_ALGORITHM: one_euro|kalman|savitzky_golay|moving_average
SMOOTHING_ALGORITHM=one_euro
# QUEUE_BACKEND: bullmq|redis|rabbitmq|sqs
QUEUE_BACKEND=bullmq
# PROGRESS_TRANSPORT: poll|push|both
PROGRESS_TRANSPORT=poll
# FRAME_SAMPLING: every|every_n|every_ms|adaptive
FRAME_SAMPLING=every_n

# Video validation thresholds
# Lists/dicts use JSON syntax when overriding via env
# SUPPORTED_FORMATS=["mp4","mov"]
# SUPPORTED_CODECS=["h264","hevc"]
MIN_DURATION_SEC=2.0
MAX_DURATION_SEC=60.0
# Resolution bounds (px), frame-rate bounds (fps), and max upload size (bytes)
MIN_WIDTH=240
MIN_HEIGHT=240
MAX_WIDTH=3840
MAX_HEIGHT=3840
MIN_FPS=10.0
MAX_FPS=120.0
MAX_SIZE_BYTES=209715200

# Frame extraction / key-frame selection
FRAME_SAMPLE_N=5
FRAME_SAMPLE_MS=200.0
MAX_KEYFRAMES=30

# Frame quality thresholds (min acceptable score per metric)
# QUALITY_THRESHOLDS={"blur":0.3,"brightness":0.2,"contrast":0.2,"motion_blur":0.3,"camera_shake":0.5,"body_visibility":0.5,"occlusion":0.5}
MIN_BRIGHTNESS=0.2
MAX_CAMERA_SHAKE=0.5

# Camera guidance thresholds (recording-setup detection, Req 22.x)
CAMERA_MIN_BODY_COVERAGE=0.95
CAMERA_MIN_BODY_AREA=0.15
CAMERA_MAX_BODY_AREA=0.80
CAMERA_MAX_VIEW_ANGLE_DEG=30.0
CAMERA_MIN_BRIGHTNESS=0.2
CAMERA_MAX_SHAKE=0.5
CAMERA_EXPECTED_ORIENTATION=portrait
CAMERA_MAX_PEOPLE=1

# Confidence thresholds
DETECTION_CONFIDENCE_MIN=0.5
POSE_LANDMARK_CONFIDENCE_MIN=0.3
POSE_OVERALL_CONFIDENCE_MIN=0.5

# Landmark validation (max normalized inter-frame jump)
MAX_LANDMARK_JUMP=0.25
# Anatomical bone-length plausibility — bone length relative to torso reference
BONE_LENGTH_MIN_RATIO=0.05
BONE_LENGTH_MAX_RATIO=3.0
# Anatomical joint-angle bounds in degrees (unsigned angle per hinge joint)
# ANATOMICAL_ANGLE_BOUNDS={"left_elbow":[0.0,180.0],"right_elbow":[0.0,180.0],"left_knee":[0.0,180.0],"right_knee":[0.0,180.0]}

# Confidence fusion (weights must sum to 1.0; no single source may dominate)
# FUSION_WEIGHTS={"vision":0.15,"pose":0.2,"detection":0.15,"movement_quality":0.15,"biomechanics":0.2,"reasoning":0.15}
FUSION_MAX_SINGLE_WEIGHT=0.4

# Rep counting (generic movement-cycle detection, Req 23.x)
# REP_MIN_AMPLITUDE: min normalized oscillation amplitude below which no reps are counted
REP_MIN_AMPLITUDE=0.001
# REP_HYSTERESIS_FRACTION: central dead-band width as a fraction of the signal range
REP_HYSTERESIS_FRACTION=0.3

# ══════════════════════════════════════════════════════════════════════════
# AI Exercise Analysis — Version 2 (Production Extensions)
# All keys below are ADDITIVE and consumed by app/analysis_v2/config_v2.py.
# Every key has a documented safe default; leave unset to use the default.
# ══════════════════════════════════════════════════════════════════════════

# ── Video Compression (Req 32) ──
COMPRESSION_TARGET_RESOLUTION=720
COMPRESSION_TARGET_FPS=30
COMPRESSION_CODEC=h264
COMPRESSION_TARGET_BITRATE_KBPS=2500
COMPRESSION_TARGET_QUALITY=0.85
# Target compressed size (MB); must stay within [5, 15]
COMPRESSION_TARGET_SIZE_MB=10.0
COMPRESSION_TARGET_SIZE_MIN_MB=5.0
COMPRESSION_TARGET_SIZE_MAX_MB=15.0
COMPRESSION_MAX_TIME_MS=30000

# ── Chunked Upload (Req 33) — chunk size bounded [1, 50] MB ──
CHUNK_SIZE_MB=5.0
CHUNK_SIZE_MIN_MB=1.0
CHUNK_SIZE_MAX_MB=50.0
CHUNK_MAX_RETRIES=3
UPLOAD_RESUME_WINDOW_HOURS=24

# ── Duplicate Detection (Req 34) / Abuse Protection (Req 47) ──
DUPLICATE_LOOKUP_TIMEOUT_MS=2000
ABUSE_CONTENT_THRESHOLD=0.6

# ── Recording Assistant (Req 35/46) ──
RECORDING_REFRESH_INTERVAL_MS=300
RECORDING_MAX_ANALYSIS_LATENCY_MS=200
# Configured severity ranking (most-blocking first); JSON list when overriding
# RECORDING_SEVERITY_ORDER=["multiple_people","body_cropped","head_missing","feet_missing","distance_too_far","distance_too_close","camera_too_low","camera_too_high","wrong_orientation","poor_lighting","backlight","camera_shaking"]

# ── Retry Manager (Req 36) — RETRY_MAX bounded [0, 10] ──
RETRY_MAX=3
RETRY_MAX_LIMIT=10
RETRY_INITIAL_DELAY_MS=200
RETRY_MULTIPLIER=2.0
RETRY_MAX_DELAY_MS=10000
RETRY_MAX_JITTER_MS=250

# ── GPU Failure Recovery (Req 37) ──
GPU_MAX_RESTART_ATTEMPTS=3
GPU_FAILURE_LIMIT=5
GPU_FAILURE_WINDOW_MS=300000
GPU_FALLBACK_MODEL=movenet
WORKER_HEALTH_POLL_S=15

# ── Caches (Req 38, 39) ──
FRAME_CACHE_MAX=2000
POSE_CACHE_MAX=2000

# ── Human Review (Req 42) / Active Models (Req 43) ──
# REVIEW_THRESHOLD bounded [0, 1]; below threshold => Needs Review
REVIEW_THRESHOLD=0.6
ACTIVE_VISION_MODEL=mediapipe
ACTIVE_POSE_MODEL=mediapipe
ACTIVE_REASONING_MODEL=default

# ── Offline Queue (Req 45) / Admin (Req 39/46) / Secure Storage (Req 51) ──
OFFLINE_MAX_UPLOAD_RETRIES=5
OFFLINE_RECONNECT_DETECT_S=30
ADMIN_METRIC_INTERVAL_S=60
ADMIN_AGGREGATION_WINDOW_MIN=5
SECURE_DELETE_MAX_RETRIES=3
SECURE_DELETE_DEADLINE_S=5

# ── Benchmark Dataset Builder (Req 41) ──
BENCHMARK_ENABLED=true
